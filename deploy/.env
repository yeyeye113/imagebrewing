# ============================================================
# 部署配置
# ============================================================
#
# 架构:
#   本地机器 (Docker) → frpc → VPS (62.234.39.66) → 互联网
#
# 域名:
#   sim.imagebrewing.com  - 未来模拟引擎
#   quant.imagebrewing.com - 量化交易
#
# ============================================================

# VPS 配置
VPS_HOST=62.234.39.66
VPS_USER=root
VPS_SSH_PORT=22

# frpc 配置
FRPS_SERVER=liangquan.com
FRPS_PORT=7000

# Docker 镜像
FUTURE_SIM_IMAGE=ghcr.io/yeyeye113/imagebrewing-future-sim:latest
QUANT_TRADER_IMAGE=ghcr.io/yeyeye113/imagebrewing-quant-trader:latest
QUANT_MONITOR_IMAGE=ghcr.io/yeyeye113/imagebrewing-quant-monitor:latest

# 本地容器名称
FUTURE_SIM_CONTAINER=future-sim
QUANT_TRADER_CONTAINER=quanttrader
QUANT_MONITOR_CONTAINER=quant-monitor

# 本地端口
FUTURE_SIM_PORT=80
QUANT_TRADER_PORT=8010
QUANT_MONITOR_PORT=8081
